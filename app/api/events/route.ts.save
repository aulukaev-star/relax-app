import { prisma } from "@/lib/prisma"
import { NextResponse } from "next/server"

export async function GET() {
  const events = await prisma.event.findMany({
    include: {
      employees: {
        include: {
          employee: true,
        },
      },
    },
  })

  return NextResponse.json(events)
}

